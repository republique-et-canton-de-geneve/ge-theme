{
  "name": "@ael/ge-header-public",
  "version": "2.0.2",
  "private": false,
  "description": "Web‑component that renders public Geneva websites header.",
  "license": "Apache-2.0",
  "type": "module",
  "source": {
    "./dist/*": "./src/$1"
  },
  "module": "dist/ge-header-public.js",
  "targets": {
    "module": {
      "source": "src/ge-header-public.js",
      "includeNodeModules": true,
      "outputFormat": "esmodule"
    },
    "dev": {
      "source": "dev/index.html",
      "distDir": ".dev-dist",
      "includeNodeModules": true
    }
  },
  "exports": {
    ".": {
      "import": "./dist/ge-header-public.js",
      "types": "./dist/types/ge-header-public.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist .parcel-cache .dev-dist",
    "copy:types": "copyfiles -u 1 \"src/**/*.d.ts\" dist/types",
    "build": "yarn clean && parcel build --target module --no-content-hash --no-source-maps && yarn copy:types",
    "lint": "eslint . --ext .js",
    "typecheck": "echo \"No TypeScript check needed for JS package (only manual .d.ts)\"",
    "prepublishOnly": "yarn build",
    "build:demo": "parcel build --target dev",
    "dev": "concurrently \"parcel watch --target dev --no-hmr\" \"sirv .dev-dist --port 1234 --dev\"",
    "start": "yarn dev"
  },
  "alias": {
    "@icons/common": "../../website/static/theme/icons/common",
    "@m3e/core": "../../../node_modules/@m3e/core",
    "@m3e/core/a11y": "../../../node_modules/@m3e/core/dist/a11y.js"
  },
  "dependencies": {
    "@m3e/button": "^1.1.8",
    "@m3e/core": "^1.1.8",
    "@m3e/divider": "~1.2.2",
    "@m3e/icon-button": "~1.2.2",
"@swc/helpers": "^0.5.17",
    "@fontsource/roboto": "5.2.5",
    "lit": "3.3.1"
  },
  "devDependencies": {
    "concurrently": "9.1.2",
    "copyfiles": "2.4.1",
    "eslint": "9.39.2",
    "parcel": "2.16.4",
    "rimraf": "6.0.1",
    "sirv-cli": "3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.devops.etat-ge.ch/ctinexus/content/repositories/npm_release/"
  },
  "keywords": [
    "web‑components",
    "geneva",
    "header",
    "design‑system"
  ]
}
